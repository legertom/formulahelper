# Required for local dev. Get one at https://vercel.com/dashboard → AI Gateway → API Keys.
# In production on Vercel, OIDC handles auth and this is not needed.
AI_GATEWAY_API_KEY=

# Optional. Override the default model. Defaults to anthropic/claude-sonnet-4.6.
# IDM_MODEL=anthropic/claude-sonnet-4.6

# Optional. Override the IDM API root. Defaults to https://formulastudio.net.
# IDM_API_BASE=https://formulastudio.net
